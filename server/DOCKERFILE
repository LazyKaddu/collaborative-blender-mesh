# === STAGE 1: COMPILATION LAYER ===
FROM node:22-alpine AS builder

WORKDIR /app

# Copy package configurations first to maximize Docker layer caching
COPY package*.json ./

# Install ALL dependencies (including devDependencies like typescript/esbuild)
RUN npm ci

# Copy the rest of your server source code
COPY . .

# Run the compilation script to turn TS into JS inside /app/dist
RUN npm run build

# === STAGE 2: PRODUCTION RUNTIME LAYER ===
FROM node:22-alpine AS runner

WORKDIR /app
ENV NODE_ENV=production

# Copy package configurations again
COPY package*.json ./

# Install ONLY production dependencies (clean and lightweight)
RUN npm ci --only=production

# Pull ONLY the compiled JavaScript code from the builder stage
COPY --from=builder /app/dist ./dist

# Expose your WebSocket server port
EXPOSE 8080

# Run the compiled javascript server
CMD ["node", "dist/server.js"]